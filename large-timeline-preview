<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Flimp Timeline Generator</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --dark:#08212D;
  --dark-mid:#122e3d;
  --lime:#67E74E;
  --lime-dark:#4cc235;
  --blue:#367ED4;
  --blue-bg:#E9F0FB;
  --red:#D83A31;
  --red-bg:#FBECEB;
  --green:#44A55D;
  --green-bg:#F2F8F0;
  --amber:#FFB21B;
  --warm-white:#FEFBF5;
  --border:#dde3ec;
  --border-light:#edf0f5;
  --text:#08212D;
  --text-secondary:#3d5a68;
  --text-tertiary:#7a96a3;
  --bg:#F2F8F0;
  --surface:#ffffff;
  --radius:8px;
  --radius-lg:12px;
}
html{font-size:14px}
body{font-family:Calibri,sans-serif;background:#F2F8F0;color:var(--text);min-height:100vh}

/* ── Header ── */
.app-header{background:var(--dark);padding:0 2rem;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.logo{display:flex;align-items:center;gap:10px}
.logo-mark{width:28px;height:28px;background:#ffffff20;border-radius:6px;display:flex;align-items:center;justify-content:center}
.logo-mark svg{width:16px;height:16px;fill:#fff}
.logo-text{font-size:15px;font-weight:600;color:#fff;letter-spacing:.02em}
.logo-sub{font-size:12px;color:#ffffff60;margin-left:2px}
.header-right{font-size:12px;color:#ffffff50}

/* ── Layout ── */
.page{max-width:900px;margin:0 auto;padding:2rem 1.5rem 4rem}

/* ── Section titles ── */
.section-head{display:flex;align-items:center;gap:10px;margin-bottom:1rem}
.section-num{width:22px;height:22px;border-radius:50%;background:var(--dark);color:#fff;font-size:11px;font-weight:600;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.section-title{font-size:13px;font-weight:600;color:var(--text);letter-spacing:.03em;text-transform:uppercase}

/* ── Cards ── */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:1.5rem;margin-bottom:1.25rem}

/* ── Form fields ── */
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px}
.field{display:flex;flex-direction:column;gap:5px}
.field label{font-size:11px;font-weight:600;color:var(--text-secondary);letter-spacing:.05em;text-transform:uppercase}
.field input,.field select{font-family:Calibri,sans-serif;font-size:14px;height:38px;padding:0 12px;background:#fff;border:1px solid var(--border);border-radius:var(--radius);color:var(--text);width:100%;transition:border-color .15s,box-shadow .15s}
.field input:focus,.field select:focus{outline:none;border-color:var(--blue);box-shadow:0 0 0 3px rgba(54,126,212,.12)}

/* ── Net new checkbox ── */
.net-new-wrap{margin:10px 0 0}
.net-new-label{display:inline-flex;align-items:center;gap:8px;padding:7px 12px;border:1px solid var(--border);border-radius:var(--radius);cursor:pointer;transition:all .15s;user-select:none}
.net-new-label:hover{border-color:#aab5d0}
.net-new-label.active{border-color:var(--blue);background:var(--blue-bg)}
.net-new-label input{width:14px;height:14px;accent-color:var(--blue);cursor:pointer}
.net-new-label .nn-text{font-size:13px;color:var(--text)}
.net-new-label .nn-hint{font-size:11px;color:var(--text-tertiary);margin-left:2px}
.net-new-label.active .nn-hint{color:var(--blue)}

/* ── Days toggle ── */
.days-group{display:flex;border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;height:38px}
.day-btn{flex:1;border:none;border-right:1px solid var(--border);background:#fff;color:var(--text-secondary);font-family:Calibri,sans-serif;font-size:13px;cursor:pointer;transition:all .15s}
.day-btn:last-child{border-right:none}
.day-btn:hover{background:var(--green-bg)}
.day-btn.active{background:var(--dark);color:var(--lime);font-weight:600}

/* ── Deliverable rows ── */
.row-headers{display:grid;grid-template-columns:1fr 72px 108px 110px 32px;gap:8px;margin-bottom:6px;padding:0 2px}
.row-headers span{font-size:11px;font-weight:600;color:var(--text-tertiary);letter-spacing:.04em;text-transform:uppercase}
.row-headers span:nth-child(2),.row-headers span:nth-child(3){text-align:center}
.del-row{display:grid;grid-template-columns:1fr 72px 108px 110px 32px;gap:8px;align-items:center;margin-bottom:8px}
.del-row select{font-family:Calibri,sans-serif;font-size:13px;height:36px;padding:0 8px;background:#fff;border:1px solid var(--border);border-radius:var(--radius);color:var(--text);width:100%;transition:border-color .15s}
.del-row select:focus{outline:none;border-color:var(--blue)}
.del-row input[type=number]{font-family:Calibri,sans-serif;font-size:14px;height:36px;padding:0 8px;border:1px solid var(--border);border-radius:var(--radius);background:#fff;color:var(--text);text-align:center;width:100%}
.del-row input[type=number]:focus{outline:none;border-color:var(--blue)}
.nr-toggle{display:flex;border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;height:36px}
.nr-btn{flex:1;border:none;background:#fff;color:var(--text-secondary);font-family:Calibri,sans-serif;font-size:12px;font-weight:500;cursor:pointer;transition:all .12s;border-right:1px solid var(--border)}
.nr-btn:last-child{border-right:none}
.nr-toggle.disabled{opacity:.35;pointer-events:none;cursor:not-allowed}
.nr-toggle.disabled .nr-btn{background:#f5f5f5;color:#aaa}
.nr-btn.n-active{background:var(--dark);color:var(--lime)}
.nr-btn.r-active{background:var(--green);color:#fff}
.rounds-stepper{display:flex;align-items:center;border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;height:36px;background:#fff}
.rounds-btn{width:28px;height:100%;border:none;background:transparent;color:var(--text-secondary);font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .12s;flex-shrink:0;font-family:Calibri,sans-serif}
.rounds-btn:hover{background:var(--blue-bg);color:var(--blue)}
.rounds-val{flex:1;text-align:center;font-size:14px;font-weight:600;color:var(--text);font-family:Calibri,sans-serif;border-left:1px solid var(--border);border-right:1px solid var(--border);height:100%;display:flex;align-items:center;justify-content:center;min-width:28px}
.rm-btn{width:32px;height:32px;border:1px solid var(--border);border-radius:var(--radius);background:transparent;color:var(--text-tertiary);cursor:pointer;font-size:17px;display:flex;align-items:center;justify-content:center;transition:all .15s;line-height:1;padding:0}
.rm-btn:hover{border-color:var(--red);color:var(--red);background:var(--red-bg)}
.add-row-btn{width:100%;height:36px;border:1px dashed var(--border);border-radius:var(--radius);background:transparent;color:var(--text-tertiary);font-family:Calibri,sans-serif;font-size:13px;cursor:pointer;margin-top:4px;transition:all .15s}
.add-row-btn:hover{border-color:var(--blue);color:var(--text)}

/* ── Checkboxes ── */
.pill-grid{display:flex;flex-wrap:wrap;gap:8px}
.pill-item{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border:1.5px solid var(--border);border-radius:20px;cursor:pointer;transition:all .18s;user-select:none;font-size:13px;color:var(--text-secondary);background:var(--surface);font-family:Calibri,sans-serif}
.pill-item:hover{border-color:var(--blue);color:var(--text);background:var(--blue-bg)}
.pill-item.checked{border-color:var(--dark);background:var(--dark);color:var(--lime);font-weight:600}
.pill-item .pill-check{width:14px;height:14px;border-radius:50%;border:1.5px solid currentColor;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .18s}
.pill-item.checked .pill-check{background:var(--lime);border-color:var(--lime)}
.pill-item.checked .pill-check::after{content:'';width:4px;height:7px;border:2px solid var(--dark);border-top:none;border-left:none;transform:rotate(45deg) translate(-1px,-1px);display:block}

/* ── Generate button ── */
.generate-wrap{margin-top:1.5rem}
.generate-btn{width:100%;height:48px;background:var(--lime);border:none;border-radius:var(--radius-lg);color:var(--dark);font-family:Calibri,sans-serif;font-size:16px;font-weight:700;cursor:pointer;letter-spacing:.02em;transition:all .2s;position:relative;overflow:hidden}
.generate-btn:hover{background:var(--lime-dark)}
.generate-btn:active{transform:scale(.99)}

/* ── Divider ── */
.section-divider{height:1px;background:var(--border-light);margin:2rem 0}

/* ── Timeline output ── */
#timelineOutput{display:none}
.tl-header{background:var(--dark);border-radius:var(--radius-lg);padding:1.5rem 1.75rem;margin-bottom:1rem;display:flex;justify-content:space-between;align-items:flex-start}
.tl-header-left .tl-project{font-size:18px;font-weight:600;color:#fff}
.tl-header-left .tl-client{font-size:13px;color:#ffffff80;margin-top:3px}
.tl-header-left .tl-badges{display:flex;gap:6px;margin-top:10px}
.tl-badge{font-size:11px;padding:3px 9px;border-radius:20px;background:#ffffff18;color:#ffffffcc;font-weight:500}
.tl-badge.new-badge{background:#0d3040;color:var(--lime)}
.tl-header-right{text-align:right}
.tl-header-right .tl-dates{font-size:13px;color:#ffffff80}
.tl-header-right .tl-dates strong{color:#fff;display:block;font-size:14px}

.tl-actions{display:flex;gap:8px;margin-bottom:1.25rem}
.tl-action-btn{height:34px;padding:0 16px;border:1px solid var(--border);border-radius:var(--radius);background:#fff;color:var(--text-secondary);font-family:Calibri,sans-serif;font-size:13px;cursor:pointer;display:flex;align-items:center;gap:6px;transition:all .15s}
.tl-action-btn:hover{border-color:var(--blue);color:var(--text)}
.tl-action-btn svg{width:14px;height:14px;flex-shrink:0}

/* product block */
.product-block{background:#fff;border:1px solid var(--border);border-radius:var(--radius-lg);margin-bottom:1rem;overflow:hidden}
.product-block-header{padding:.9rem 1.25rem;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border-light)}
.pbh-left{display:flex;align-items:center;gap:10px}
.product-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.product-name{font-size:14px;font-weight:600;color:var(--text)}
.product-meta{font-size:12px;color:var(--text-tertiary);margin-top:1px}
.product-badge{font-size:11px;padding:3px 8px;border-radius:20px;font-weight:500}
.badge-new{background:var(--blue-bg);color:var(--blue)}
.badge-renewal{background:var(--green-bg);color:var(--green)}

/* milestone list */
.milestone-list{padding:.5rem 0}
.milestone-row{display:grid;grid-template-columns:28px 1fr auto;gap:0;align-items:start;padding:.55rem 1.25rem;transition:background .1s}
.milestone-row:hover{background:var(--warm-white)}
.milestone-row:last-child{border-bottom:none}
.ms-connector{display:flex;flex-direction:column;align-items:center;padding-top:4px}
.ms-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.ms-line{width:1px;background:var(--border);flex:1;min-height:16px;margin-top:3px}
.milestone-row:last-child .ms-line{display:none}
.ms-content{}
.ms-phase{font-size:13px;color:var(--text);font-weight:500;line-height:1.3}
.ms-owner{font-size:11px;color:var(--text-tertiary);margin-top:2px}
.ms-owner .owner-tag{display:inline-block;padding:1px 6px;border-radius:3px;font-size:10px;font-weight:600;letter-spacing:.03em}
.owner-flimp{background:var(--blue-bg);color:var(--blue)}
.owner-client{background:var(--green-bg);color:var(--green)}
.ms-date{text-align:right}
.ms-date-val{font-size:13px;font-weight:600;color:var(--text);white-space:nowrap}
.ms-date-day{font-size:11px;color:var(--text-tertiary);margin-top:2px}

/* deadline warning */
.deadline-warn{background:var(--red-bg);border:1px solid #f0b0ac;border-radius:var(--radius);padding:.6rem 1rem;margin:.75rem 1.25rem;font-size:12px;color:var(--red);display:flex;align-items:center;gap:8px}
.deadline-warn svg{width:14px;height:14px;flex-shrink:0;fill:#f9a825}

/* summary footer */
.tl-summary{background:#f7f8fc;border:1px solid var(--border);border-radius:var(--radius-lg);padding:1rem 1.25rem;display:flex;gap:2rem;flex-wrap:wrap}
.sum-item{display:flex;flex-direction:column;gap:2px}
.sum-label{font-size:11px;color:var(--text-tertiary);text-transform:uppercase;letter-spacing:.05em;font-weight:600}
.sum-val{font-size:15px;font-weight:600;color:var(--text)}

/* net new onboarding note */
.nn-note{background:var(--blue-bg);border-left:3px solid var(--blue);border-radius:0 var(--radius) var(--radius) 0;padding:.85rem 1.1rem;margin-bottom:1rem;font-size:13px;color:#1a3d6a;line-height:1.6}
.nn-note strong{display:block;font-size:12px;text-transform:uppercase;letter-spacing:.05em;color:var(--blue);margin-bottom:4px}


/* ── Phase Preview ── */
#phasePreviewSection{display:none}
.preview-btn{width:100%;height:44px;background:#fff;border:1.5px solid var(--dark);border-radius:var(--radius-lg);color:var(--dark);font-family:Calibri,sans-serif;font-size:15px;font-weight:600;cursor:pointer;transition:all .2s;margin-top:1.25rem}
.preview-btn:hover{background:var(--green-bg)}
.pb-block{background:#fff;border:1px solid var(--border);border-radius:var(--radius-lg);margin-bottom:.75rem;overflow:hidden}
.pb-header{padding:.8rem 1.1rem;display:flex;align-items:center;gap:10px;cursor:pointer;user-select:none;transition:background .12s}
.pb-header:hover{background:var(--warm-white)}
.pb-confirm{width:18px;height:18px;border-radius:4px;border:2px solid var(--border);background:#fff;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .15s;cursor:pointer}
.pb-confirm.confirmed{background:var(--green);border-color:var(--green)}
.pb-confirm.confirmed::after{content:'';width:5px;height:9px;border:2px solid #fff;border-top:none;border-left:none;transform:rotate(45deg) translate(-1px,-1px);display:block}
.pb-chevron{width:16px;height:16px;flex-shrink:0;margin-left:auto;transition:transform .2s;color:var(--text-tertiary)}
.pb-chevron.open{transform:rotate(180deg)}
.pb-title-wrap{flex:1;min-width:0}
.pb-title{font-size:13px;font-weight:600;color:var(--text)}
.pb-subtitle{font-size:11px;color:var(--text-tertiary);margin-top:1px}
.pb-body{border-top:1px solid var(--border-light);display:block;max-height:0;overflow:hidden;transition:max-height .35s ease}
.pb-body.open{max-height:2000px}
.phase-table{width:100%;border-collapse:collapse}
.phase-table th{font-size:11px;font-weight:600;color:var(--text-tertiary);letter-spacing:.04em;text-transform:uppercase;padding:.5rem .9rem;text-align:left;border-bottom:1px solid var(--border-light);background:var(--warm-white)}
.phase-table th:nth-child(2),.phase-table th:nth-child(3){text-align:center}
.phase-table td{padding:.45rem .9rem;border-bottom:1px solid var(--border-light);vertical-align:middle}
.phase-table tr:last-child td{border-bottom:none}
.phase-table tr:hover td{background:#fafbfd}
.pt-name{font-family:Calibri,sans-serif;font-size:13px;height:30px;padding:0 8px;border:1px solid transparent;border-radius:5px;color:var(--text);width:100%;background:transparent;transition:border-color .12s}
.pt-name:hover{border-color:var(--border)}
.pt-name:focus{outline:none;border-color:var(--blue);background:#fff}
.phase-rm-btn{width:22px;height:22px;border:1px solid var(--border);border-radius:4px;background:transparent;color:var(--text-tertiary);cursor:pointer;font-size:14px;display:inline-flex;align-items:center;justify-content:center;line-height:1;padding:0;transition:all .12s}
.phase-rm-btn:hover{border-color:var(--red);color:var(--red);background:var(--red-bg)}
.pt-dur{font-family:Calibri,sans-serif;font-size:13px;height:30px;padding:0 6px;border:1px solid transparent;border-radius:5px;color:var(--text);width:62px;text-align:center;background:transparent;transition:border-color .12s}
.pt-dur:hover{border-color:var(--border)}
.pt-dur:focus{outline:none;border-color:var(--blue);background:#fff}
.owner-badge{font-size:10px;font-weight:600;padding:2px 7px;border-radius:3px;letter-spacing:.03em}
.preview-status{display:flex;align-items:center;gap:8px;margin-top:.75rem;font-size:12px;color:var(--text-tertiary)}
.preview-status .ps-count{font-weight:600;color:var(--green)}
.generate-btn:disabled{opacity:.4;cursor:not-allowed;background:var(--border)}


/* ── Unified timeline table ── */
.unified-tl-wrap{background:#fff;border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;margin-bottom:1rem}
.unified-tl-title{padding:1rem 1.5rem .75rem;font-size:16px;font-weight:700;color:var(--text);border-bottom:1px solid var(--border-light)}
.unified-tl-table{width:100%;border-collapse:collapse;font-family:Calibri,sans-serif}
.unified-tl-table thead tr{background:var(--dark)}
.unified-tl-table th{padding:.55rem 1rem;font-size:11px;font-weight:700;color:#ffffff90;letter-spacing:.06em;text-transform:uppercase;text-align:left;border-bottom:none}
.unified-tl-table td{border-bottom:1px solid rgba(0,0,0,.06);vertical-align:middle}
.unified-tl-table tbody tr:last-child td{border-bottom:none}
.unified-tl-footer{padding:.75rem 1.5rem;font-size:12px;color:var(--text-secondary);border-top:1.5px solid var(--border);background:var(--warm-white);display:flex;gap:1.5rem;flex-wrap:wrap}
.unified-tl-footer span strong{color:var(--text);font-weight:700}

@media print{
  .app-header,.generate-wrap,.tl-actions{display:none!important}
  body{background:#fff}
  .card{border:none;padding:0}
  #timelineOutput{display:block!important}
}
</style>
</head>
<body>

<header class="app-header">
  <div class="logo">
    <span style="font-size:21px;font-weight:700;color:#67E74E;letter-spacing:-.01em">flimp</span><span style="font-size:12px;color:#ffffff45;margin-left:6px;letter-spacing:.02em">/ Timeline Generator</span>
  </div>
  <span class="header-right">Internal Tool</span>
</header>

<div class="page">

  <!-- SECTION 1: PROJECT INFO -->
  <div class="section-head"><div class="section-num">1</div><span class="section-title">Project Information</span></div>
  <div class="card">
    <div class="grid2" style="margin-bottom:10px">
      <div class="field"><label>Client name</label><input type="text" id="clientName" placeholder="e.g. Acme Corporation"></div>
      <div class="field"><label>Project name</label><input type="text" id="projectName" placeholder="e.g. 2025 Benefits Communication"></div>
    </div>
    <div class="net-new-wrap">
      <label class="net-new-label" id="nnLabel">
        <input type="checkbox" id="netNewCb" onchange="toggleNetNew()">
        <span class="nn-text">Net new client</span>
        <span class="nn-hint">— adds additional context to export</span>
      </label>
    </div>
    <div style="height:14px"></div>
    <div class="grid3">
      <div class="field"><label>Start date</label><input type="date" id="startDate"></div>
      <div class="field"><label>Due date</label><input type="date" id="dueDate"></div>
      <div class="field">
        <label>Working days / week</label>
        <select id="workingDaysSelect" onchange="setDays(this.value)" style="font-family:Calibri,sans-serif">
          <option value="5" selected>5 days (Mon–Fri)</option>
          <option value="6">6 days (Mon–Sat)</option>
          <option value="7">7 days (Mon–Sun)</option>
        </select>
      </div>
    </div>
  </div>

  <!-- SECTION 2: DELIVERABLES -->
  <div class="section-head"><div class="section-num">2</div><span class="section-title">Deliverables</span></div>
  <div class="card">
    <div class="row-headers">
      <span>Product</span><span>Count</span><span>New / Renewal</span><span style="text-align:center">Rounds of edits</span><span></span>
    </div>
    <div id="delRows"></div>
    <button class="add-row-btn" onclick="addRow()">+ Add deliverable</button>
  </div>

  <!-- SECTION 3: ADDITIONAL -->
  <div class="section-head"><div class="section-num">3</div><span class="section-title">Additional Items</span></div>
  <div class="card">
    <div class="pill-grid" id="addlGrid">
      <div class="pill-item" onclick="togglePill(this)"><div class="pill-check"></div>Library Videos</div>
      <div class="pill-item" onclick="togglePill(this)"><div class="pill-check"></div>Print &amp; Mail</div>
      <div class="pill-item" onclick="togglePill(this)"><div class="pill-check"></div>Writing Services</div>
    </div>
  </div>

  <button class="preview-btn" onclick="previewPhases()">&#9654; Preview &amp; Edit Phases</button>

  <!-- SECTION 4: PHASE PREVIEW -->
  <div id="phasePreviewSection">
    <div style="height:1.5rem"></div>
    <div class="section-head"><div class="section-num">4</div><span class="section-title">Review Phases</span><span style="font-size:12px;color:var(--text-tertiary);margin-left:4px">— click "Confirmed" to approve the proposed timeline for each deliverable</span></div>
    <div id="tlValidation" style="display:none;margin-bottom:1rem;border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden">
      <div style="background:var(--dark);padding:.65rem 1.25rem;display:flex;align-items:center;justify-content:space-between">
        <span style="font-size:11px;font-weight:700;color:#fff;letter-spacing:.06em;text-transform:uppercase">Timeline Feasibility</span>
        <span style="font-size:11px;color:#ffffff60" id="tlValDates"></span>
      </div>
