function calcBusinessDaysInRange(start, end){
  if(!start||!end||end<=start)return 0;
  let count=0;
  let d=new Date(start);
  d.setDate(d.getDate()+1);
  while(d<=end){
    if(isWorkDay(d))count++;
    d.setDate(d.getDate()+1);
  }
  return count;
}

function updateValidation(){
  const startVal=document.getElementById('startDate').value;
  const dueVal=document.getElementById('dueDate').value;
  const valEl=document.getElementById('tlValidation');
  if(!valEl)return;

  if(!startVal){valEl.style.display='none';return;}
  valEl.style.display='block';

  const startDate=new Date(startVal+'T00:00:00');
  const dueDate=dueVal?new Date(dueVal+'T00:00:00'):null;

  // Calculate available business days
  const available=dueDate?calcBusinessDaysInRange(startDate,dueDate):null;
  document.getElementById('tlValAvailable').textContent=available!==null?available:'—';
  document.getElementById('tlValDates').textContent=dueDate?`${fmtDateShort(startDate)} → ${fmtDateShort(dueDate)}`:'No due date set';

  // Calculate needed days: longest parallel track + end-sequential sum
  const blocks=[...document.querySelectorAll('#pbBlocks .pb-block')];
  if(!blocks.length){
    document.getElementById('tlValNeeded').textContent='—';
    document.getElementById('tlValDiff').textContent='—';
    document.getElementById('tlValMsg').textContent='—';
    document.getElementById('tlValFill').style.width='0%';
    return;
  }

  // Get deliverables to know which are end products
  const rows=[...document.querySelectorAll('#delRows .del-row')];
  const deliverables=rows.map(r=>({
    product:r.querySelector('select').value
  })).filter(d=>d.product);

  let maxParallelDays=0;
  let totalEndDays=0;
  blocks.forEach((block,i)=>{
    const product=deliverables[i]?deliverables[i].product:'';
    const isEnd=END_PRODUCTS.includes(product);
    const total=[...block.querySelectorAll('.pt-dur')].reduce((sum,inp)=>sum+(parseInt(inp.value)||0),0);
    if(isEnd){
      totalEndDays=Math.max(totalEndDays,total);
    } else {
      if(total>maxParallelDays)maxParallelDays=total;
    }
  });

  const needed=maxParallelDays+totalEndDays;
  document.getElementById('tlValNeeded').textContent=needed;

  if(available===null){
    document.getElementById('tlValDiff').textContent='—';
    document.getElementById('tlValMsg').textContent='Set a due date to check feasibility';
    document.getElementById('tlValFill').style.width='0%';
    document.getElementById('tlValFill').style.background='var(--border)';
    document.getElementById('tlValDiff').style.color='var(--text)';
    return;
  }

  const diff=available-needed;
  const diffEl=document.getElementById('tlValDiff');
  const msgEl=document.getElementById('tlValMsg');
  const fillEl=document.getElementById('tlValFill');
  const pct=Math.min(100,Math.round((needed/Math.max(available,needed))*100));

  diffEl.textContent=(diff>=0?'+':'')+diff+' days';

  if(diff>=6){
    diffEl.style.color='#2e8b4a';
    msgEl.textContent='Timeline fits with buffer';
    msgEl.style.color='#2e8b4a';
    fillEl.style.width=pct+'%';
    fillEl.style.background='#44A55D';
  } else if(diff>=1){
    diffEl.style.color='#b5920a';
    msgEl.textContent='Tight but feasible — only '+diff+' day'+(diff===1?'':'s')+' buffer';
    msgEl.style.color='#b5920a';
    fillEl.style.width=pct+'%';
    fillEl.style.background='var(--amber)';
  } else if(diff===0){
    diffEl.style.color='#b5920a';
    msgEl.textContent='Exactly on time — no buffer';
    msgEl.style.color='#b5920a';
    fillEl.style.width='100%';
    fillEl.style.background='var(--amber)';
  } else {
    diffEl.style.color='var(--red)';
    msgEl.textContent=Math.abs(diff)+' days over — consider compressing';
    msgEl.style.color='var(--red)';
    fillEl.style.width='100%';
    fillEl.style.background='var(--red)';
  }
}

function updateGenerateBtn(){
  const psCount=document.getElementById('psCount');
  const generateBtn=document.getElementById('generateBtn');
  if(!psCount||!generateBtn)return;
  const blocks=[...document.querySelectorAll('#pbBlocks .pb-block')];
  const total=blocks.length;
  const confirmed=blocks.filter(b=>b.dataset.confirmed==='true').length;
  psCount.textContent=`${confirmed} / ${total}`;
  generateBtn.disabled=(confirmed<total)||total===0;
  updateValidation();
}

// ── Generate ──────────────────────────────────────────────────────────────
function generateTimeline(){
  const client=document.getElementById('clientName').value.trim()||'Client';
  const project=document.getElementById('projectName').value.trim()||'Untitled Project';
  const startVal=document.getElementById('startDate').value;
  const dueVal=document.getElementById('dueDate').value;
  const isNetNew=document.getElementById('netNewCb').checked;

  if(!startVal){alert('Please enter a start date.');return;}

  const startDate=nextWorkDay(new Date(startVal+'T00:00:00'));
  const dueDate=dueVal?new Date(dueVal+'T00:00:00'):null;

  // Collect deliverables
  const rows=[...document.querySelectorAll('#delRows .del-row')];
  const deliverables=rows.map(r=>{
    const sel=r.querySelector('select');
    const cnt=parseInt(r.querySelector('input[type=number]').value)||1;
    const isRenewal=r.querySelector('.nr-btn.r-active')!==null;
    const rounds=parseInt(r.querySelector('.rounds-val').textContent)||2;
    return{product:sel.value,count:cnt,isRenewal,rounds};
  }).filter(d=>d.product);

  if(!deliverables.length){alert('Please select at least one product.');return;}

  // Additional items
  const addl=[...document.querySelectorAll('#addlGrid .pill-item.checked')].map(el=>el.childNodes[1].textContent.trim());

  // Read edited phases from preview blocks
  const previewBlocks=[...document.querySelectorAll('#pbBlocks .pb-block')];
  let blockIdx=0;

  // Reset color assignments for this generation
  Object.keys(productColorMap).forEach(k=>delete productColorMap[k]);
  colorIdx=0;

  // Split deliverables into parallel (standard) and end-sequential groups
  const parallelDels=deliverables.filter(d=>!END_PRODUCTS.includes(d.product));
  const endDels=deliverables.filter(d=>END_PRODUCTS.includes(d.product));

  const allMilestones=[];
  let parallelEndDate=new Date(startDate);
  let projectEndDate=new Date(startDate);
  let totalWorkDays=0;

  // ── Pass 1: Parallel deliverables (all start on startDate) ───────────────
  parallelDels.forEach(del=>{
    const deliverableLabel=del.product;
    let vDate=new Date(startDate);

    const previewBlock=previewBlocks[blockIdx++];
    const phases=previewBlock?[...previewBlock.querySelectorAll('.phase-table tbody tr')].map(tr=>{
      const inputs=[...tr.querySelectorAll('input')];
      const ownerEl=tr.querySelector('.owner-badge');
      return{name:inputs[0].value.trim(),dur:parseInt(inputs[1].value)||1,owner:ownerEl?ownerEl.textContent.trim():'Flimp'};
    }):[];

    phases.forEach(phase=>{
      const endDate=addBusinessDays(vDate,phase.dur);
      totalWorkDays+=phase.dur;
      allMilestones.push({
        date:new Date(endDate),
        dateSort:endDate.getTime(),
        owner:phase.owner,
        deliverable:deliverableLabel,
        product:del.product,
        task:phase.name,
      });
      if(endDate>parallelEndDate)parallelEndDate=new Date(endDate);
      if(endDate>projectEndDate)projectEndDate=new Date(endDate);
      vDate=nextWorkDay(new Date(endDate));
    });
  });

  // ── Pass 2: End deliverables (all start after parallel block ends, run in parallel with each other) ──
  const endStartDate=parallelDels.length>0?nextWorkDay(new Date(parallelEndDate)):new Date(startDate);

  endDels.forEach(del=>{
    const deliverableLabel=del.product;
    let vDate=new Date(endStartDate);

    const previewBlock=previewBlocks[blockIdx++];
    const phases=previewBlock?[...previewBlock.querySelectorAll('.phase-table tbody tr')].map(tr=>{
      const inputs=[...tr.querySelectorAll('input')];
      const ownerEl=tr.querySelector('.owner-badge');
      return{name:inputs[0].value.trim(),dur:parseInt(inputs[1].value)||1,owner:ownerEl?ownerEl.textContent.trim():'Flimp'};
    }):[];

    phases.forEach(phase=>{
      const endDate=addBusinessDays(vDate,phase.dur);
      totalWorkDays+=phase.dur;
      allMilestones.push({
        date:new Date(endDate),
        dateSort:endDate.getTime(),
        owner:phase.owner,
        deliverable:deliverableLabel,
        product:del.product,
        task:phase.name,
      });
      if(endDate>projectEndDate)projectEndDate=new Date(endDate);
      vDate=nextWorkDay(new Date(endDate));
    });
  });

  // Sort all milestones by date
  allMilestones.sort((a,b)=>a.dateSort-b.dateSort);

  // Show output section
  document.getElementById('outputDivider').style.display='block';
  const output=document.getElementById('timelineOutput');
  output.style.display='block';

  // Net new note
  const nnWrap=document.getElementById('nnNoteWrap');
  if(isNetNew){
    nnWrap.innerHTML=`<div class="nn-note" style="margin-bottom:1rem">
      <strong>Net New Client</strong>
      This project involves a new client relationship with Flimp. Please allow additional time during the Kickoff and onboarding phases for account setup, portal access provisioning, and alignment on Flimp's production process and review expectations. All milestone dates assume timely client responsiveness — delays in content delivery or review rounds will push the schedule accordingly.
    </div>`;
  } else {
    nnWrap.innerHTML='';
  }

  // Title
  document.getElementById('tlTitle').textContent=project;


  // Populate table
  const tbody=document.getElementById('tlTableBody');
  tbody.innerHTML='';

  // Group milestones by date + owner (Client and Flimp never combined)
  const byDate=[];
  const dateIndex={};
  allMilestones.forEach(m=>{
    const key=fmtDateShort(m.date)+'|'+m.owner;
    if(dateIndex[key]===undefined){dateIndex[key]=byDate.length;byDate.push({key,date:m.date,owner:m.owner,items:[],isPastDue:false});}
    byDate[dateIndex[key]].items.push(m);
    if(dueDate&&m.date>dueDate)byDate[dateIndex[key]].isPastDue=true;
  });
  byDate.sort((a,b)=>a.date-b.date||a.owner.localeCompare(b.owner));

  let hasWarning=false;
  byDate.forEach(group=>{
    if(group.isPastDue)hasWarning=true;
    const tr=document.createElement('tr');
    if(group.isPastDue)tr.style.background='var(--red-bg)';

    // Build combined party, deliverable, task strings
    const parties=group.owner;
    const deliverables=[...new Set(group.items.map(m=>m.deliverable))].join(', ');
    const tasks=[...new Set(group.items.map(m=>m.task))].join(', ');

    tr.innerHTML=`
      <td style="font-size:13px;color:var(--text);padding:.5rem 1rem;border-bottom:1px solid var(--border-light);vertical-align:top">${parties}</td>
      <td style="font-size:13px;color:var(--text-secondary);padding:.5rem 1rem;border-bottom:1px solid var(--border-light);vertical-align:top">${deliverables}</td>
      <td style="font-size:13px;color:var(--text);padding:.5rem 1rem;border-bottom:1px solid var(--border-light);vertical-align:top">${tasks}</td>
      <td style="font-size:13px;font-weight:600;color:${group.isPastDue?'var(--red)':'var(--text)'};padding:.5rem 1rem;white-space:nowrap;text-align:right;border-bottom:1px solid var(--border-light);vertical-align:top">${fmtDateShort(group.date)}</td>`;
    tbody.appendChild(tr);
  });

  if(hasWarning){
    const warnTr=document.createElement('tr');
    warnTr.innerHTML=`<td colspan="4" style="background:var(--red-bg);color:var(--red);font-size:12px;padding:.5rem 1rem;font-weight:600">
      One or more phases extend past the due date. Consider compressing durations in the phase review step.
    </td>`;
    tbody.appendChild(warnTr);
  }

  // Footer
  document.getElementById('tlFooter').innerHTML=`
    <span><strong>Project Start:</strong> ${fmtDateShort(startDate)}</span>
    <span><strong>Working Days:</strong> ${totalWorkDays}</span>
    ${dueDate?`<span><strong>Due Date:</strong> ${fmtDateShort(dueDate)}</span>`:''}
    <span><strong>Projected End:</strong> ${fmtDateShort(projectEndDate)}</span>
    <span><strong>Deliverables:</strong> ${deliverables.reduce((a,d)=>a+d.count,0)}${addl.length?' + '+addl.join(', '):''}</span>`;

  output.scrollIntoView({behavior:'smooth',block:'start'});
}

// ── Init ──────────────────────────────────────────────────────────────────
const dr=document.getElementById('delRows');
for(let i=0;i<3;i++)dr.appendChild(buildDelRow());
updateRemove();

// Default start date to today
const today=new Date();
document.getElementById('startDate').value=fmtISO(today);
document.getElementById('startDate').addEventListener('change',updateValidation);
document.getElementById('dueDate').addEventListener('change',updateValidation);

// Single persistent listener for live duration edits in phase preview
document.addEventListener('input',function(e){
  if(e.target.classList.contains('pt-dur'))updateValidation();
});
</script>
